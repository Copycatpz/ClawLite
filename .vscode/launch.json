{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug ClawLite",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/clawlite.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "R:/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build (MinGW)"
        },
